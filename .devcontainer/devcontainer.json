{
  "name": "Claude Code Secure Sandbox",
  "image": "node:22-slim",
  "remoteUser": "root",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "installOhMyZsh": true,
      "configureZshAsDefaultShell": true // 🔥 THE FIX: Native shell configuration
    },
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.12"
    }
  },
  "containerEnv": {
    "GIT_CONFIG_PARAMETERS": "'safe.directory=*'"
  },
  "mounts": [
    "source=${localEnv:HOME}/.config/claude_docker_state/.claude/settings.json,target=/root/.claude/settings.json,type=bind",
    "source=${localEnv:HOME}/.config/claude_docker_state/.claude.json,target=/root/.claude.json,type=bind",
    "source=${localEnv:HOME}/.config/claude_docker_state/.claude/plugins,target=/root/.claude/plugins,type=bind",
    "source=${localEnv:HOME}/.config/claude_docker_state/.ssh,target=/root/.ssh,type=bind"
  ],
  "postCreateCommand": "npm install -g @anthropic-ai/claude-code",
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code"
      ]
      // No need for terminal settings here anymore!
    }
  }
}